{
  "view": "List",
  "name": "categories",
  "renderItem": {
    "view": "Column",
    "styles": "padding border",
    "items": [
      {
        "view": "Title",
        "label": {
          "name": "categoryID",
          "relativeData": true
        }
      },
      {
        "view": "Text",
        "label": "I'm Hidden because there is no 'data.categoryID'",
        "showIf": {
          "name": "categoryID",
          "relativeData": false
        }
      },
      {
        "view": "Text",
        "label": "You see this because <\"showIf\": \"categoryID\"> resolves to 'data.categories.{index}.categoryID', which is considered 'Truthy'",
        "showIf": "categoryID",
        "styles": "padding"
      },
      {
        "view": "Text",
        "name": "categoryID",
        "relativeData": true,
        "label": "And here is how to evaluate it <\"showIf\": {\"equal\": \"Gold\"}>",
        "showIf": {
          "equal": "Gold"
        },
        "styles": "padding"
      },
      {
        "view": "Text",
        "label": "Finally, only Silver shows up because <\"equal\": {\"name\": \"categories.1.categoryID\", \"relativeData\": false}> evaluates to 'Silver'",
        "showIf": {
          "name": "categoryID",
          "equal": {
            "name": "categories.1.categoryID",
            "relativeData": false
          }
        },
        "styles": "padding"
      }
    ]
  }
}
