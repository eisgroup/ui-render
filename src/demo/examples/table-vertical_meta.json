{
  "view": "Table",
  "name": "categories",
  "vertical": true,
  "headers": [
    {
      "id": "categoryID",
      "label": "Category Name",
      "renderCell": {
        "view": "Expand",
        "name": "{value}",
        "index": "{index}",
        "onClick": "handleItemExpand"
      }
    },
    {
      "id": "configuration.inputType",
      "label": "Contribution Type"
    },
    {
      "id": "configuration.requiredParticipationPrct",
      "label": "Contribution",
      "renderCell": "Percent"
    },
    {
      "id": "rate",
      "label": "Quote Rate",
      "renderCell": "double5"
    },
    {
      "id": "annualAmount",
      "label": "Annual Amount",
      "renderCell": "Currency"
    },
    {
      "id": "#",
      "renderHeader": {
        "view": "Checkbox",
        "label": "Expand All",
        "onChange": "handleToggleExpandAll"
      }
    }
  ]
}
